    <button class="scroll-arrow left-arrow" id="scrollLeft">&#10094;</button>

    <div class="tags-scroll" id="tagScroller" style="margin-left: 28px;
  margin-right: 21px;">
        @if (Model != null && Model.Tags.Any())
        {
            @foreach (var tag in Model.Tags)
